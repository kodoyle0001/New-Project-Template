# Normalize line endings — prevent churn and accidental diffs across Windows/Linux
* text=auto eol=lf

# Windows-native scripts keep CRLF
*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary — never normalize
*.pdf   binary
*.xlsx  binary
*.png   binary
*.jpg   binary
*.pfx   binary
*.cer   binary
